Prevalence = round(prevalence, 1),
Lower = round(ci[1], 1),    #95%信頼区間の下限値を小数第一位まで
Upper = round(ci[2], 1),    #95%信頼区間の上限値を小数第一位まで
P_value = ifelse(i == 1, format_p(p_value), "")   #format_pでP値を整形
)
#作成した一行を結果の表に追加する
result <- rbind(result, one_row)
}
#完成した表を返す
result
}
